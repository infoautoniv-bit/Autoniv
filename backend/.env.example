# ─── Core ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/autoniv
FRONTEND_URL=http://localhost:5173
ADMIN_FRONTEND_URL=http://localhost:5174
SERVER_URL=http://localhost:3000
TRUST_PROXY=false

# ─── Auth & Security ──────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
JWT_REFRESH_SECRET=change_me_to_another_long_random_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
COOKIE_DOMAIN=localhost
ENCRYPTION_KEY=change_me_32_byte_hex_key
API_KEY_HASH_SALT=change_me_random_salt
ADMIN_SECRET=change_me_admin_secret
MEDIA_STREAM_SECRET=change_me_media_stream_secret
CSRF_SECRET=change_me_64_byte_hex_string

# ─── Voice / AI Providers ─────────────────────────────
VAPI_API_KEY=your_vapi_api_key
VAPI_BASE_URL=https://api.vapi.ai
VAPI_WEBHOOK_SECRET=your_vapi_webhook_secret
WEBHOOK_URL=https://your-domain.com/api/webhooks/vapi
OPENAI_API_KEY=sk-your_openai_api_key
GROQ_API_KEY=gsk_your_groq_api_key
GEMINI_API_KEY=your_gemini_api_key
DEEPGRAM_API_KEY=your_deepgram_api_key
ELEVENLABS_API_KEY=your_elevenlabs_api_key
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=eastus
SARVAM_API_KEY=your_sarvam_api_key

# ─── Integrations ─────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM=noreply@your-domain.com
MAILERSEND_FROM_NAME=Autoniv
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_API_KEY=your_whatsapp_api_key
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
# Token the Meta webhook echoes back during GET verification (must match the value set in the Meta App dashboard)
WHATSAPP_VERIFY_TOKEN=autoniv_chatbot_verify
# Optional: WhatsApp number that receives admin/system notifications
ADMIN_WHATSAPP=

# ─── WhatsApp Embedded Signup (per-tenant "Connect WhatsApp") ─────────────
# Meta App credentials for the Embedded Signup OAuth flow. When META_APP_SECRET
# is set, inbound webhooks are verified via X-Hub-Signature-256.
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
# Embedded Signup configuration id (also exposed to the frontend as VITE_FACEBOOK_CONFIG_ID)
META_CONFIG_ID=your_embedded_signup_config_id
META_GRAPH_VERSION=v20.0
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ─── Appointments ─────────────────────────────────────
APPT_OPEN_HOUR=9
APPT_CLOSE_HOUR=18
APPT_SLOT_MINUTES=30
BUSINESS_NAME=Autoniv
