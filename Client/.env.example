# Backend API base URL
VITE_API_URL=http://localhost:3000/api

# Google OAuth client ID
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# WhatsApp Embedded Signup (Meta) — "Connect WhatsApp" button
VITE_FACEBOOK_APP_ID=your_meta_app_id
VITE_FACEBOOK_CONFIG_ID=your_embedded_signup_config_id

# Vapi public/web key for in-browser voice calls
VITE_VAPI_API_KEY=your_vapi_public_key

# Public contact details (shown on the site)
VITE_CONTACT_EMAIL=hello@your-domain.com
VITE_CONTACT_PHONE=+1 (000) 000-0000
VITE_CONTACT_PHONE_RAW=+10000000000
VITE_CONTACT_WEBSITE=https://your-domain.com
