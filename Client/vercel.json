{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.autoniv.com"
        }
      ],
      "destination": "https://autoniv.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/robots.txt", "destination": "/robots.txt" },
    { "source": "/llms.txt", "destination": "/llms.txt" },
    { "source": "/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/((?!assets/|sitemap\\.xml|robots\\.txt|llms\\.txt).*)", "destination": "/index.html" }
  ]
}
